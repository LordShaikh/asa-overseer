# Discord
DISCORD_TOKEN=your_bot_token_here
GUILD_ID=your_guild_id_here
LOG_CHANNEL_ID=your_log_channel_id_here

# EOS (Epic Online Services)
EOS_CLIENT_ID=your_eos_client_id_here
EOS_CLIENT_SECRET=your_eos_client_secret_here
EOS_DEPLOYMENT_ID=your_eos_deployment_id_here
EOS_SANDBOX_ID=your_eos_sandbox_id_here

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# RCON Servers (JSON array of {host, port, password, name})
RCON_SERVERS=[]

# Polling interval in seconds
POLL_INTERVAL=60

# Log level
LOG_LEVEL=INFO
